#
<key>TUTORIAL_02_CROUCH</key>
<string>Appuyez sur # pour vous accroupir.</string>
#
<key>TUTORIAL_03_DOWN</key>
<string>Maintenez # enfoncé pour descendre d'un étage.</string>
#
<key>TUTORIAL_04_JUMP</key>
